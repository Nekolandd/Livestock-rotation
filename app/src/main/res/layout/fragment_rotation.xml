<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F7">

    <!-- Header Title -->
    <TextView
        android:id="@+id/tvRotationTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="24dp"
        android:text="Rotación de Ganado"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvRotationSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="4dp"
        android:text="Selecciona fecha para ver históricos o programar rotación. Mantén presionado un lote para ver detalles."
        android:textSize="13sp"
        android:textColor="#757575"
        app:layout_constraintTop_toBottomOf="@id/tvRotationTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Date selector row -->
    <LinearLayout
        android:id="@+id/layoutDateSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tvRotationSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha de Consulta:"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#212121" />

        <EditText
            android:id="@+id/etRotationDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:focusable="false"
            android:clickable="true"
            android:inputType="none"
            android:background="@android:drawable/editbox_background"
            android:padding="10dp"
            android:textSize="15sp"
            android:gravity="center"
            android:text="2026-06-13" />

    </LinearLayout>

    <!-- RecyclerView for rotation status list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRotation"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:clipToPadding="false"
        android:paddingBottom="70dp"
        app:layout_constraintTop_toBottomOf="@id/layoutDateSelector"
        app:layout_constraintBottom_toTopOf="@id/btnLoadCattle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Button Load Cattle -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLoadCattle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:padding="14dp"
        android:text="Cargar Ganado en Lotes"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        app:backgroundTint="#EF5350"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
